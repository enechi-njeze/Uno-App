{
  "expo": {
    "name": "Unö",
    "slug": "uno-app",
    "scheme": "uno",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/brand/uno-icon-1024.png",
    "splash": {
      "image": "./assets/brand/uno-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B3D2E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ng.uno.app"
    },
    "android": {
      "package": "ng.uno.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/uno-icon-foreground.png",
        "backgroundColor": "#0B3D2E"
      }
    },
    "extra": {
      "//": "API base URL. Override per-device via the EXPO_PUBLIC_API_URL env var (see README). This 'extra' value is the fallback the app reads when that env var is unset.",
      "apiUrl": "http://localhost:3000/api/v1"
    }
  }
}

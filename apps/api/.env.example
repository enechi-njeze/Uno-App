# Copy to .env and adjust. Never commit .env.
NODE_ENV=development
PORT=3000

# Postgres connection.
# Local docker-compose default is: postgresql://uno:uno@localhost:5432/uno
DATABASE_URL=postgresql://uno:uno@localhost:5432/uno

# CORS: comma-separated origins allowed to call the API.
# For Expo dev, the app connects over HTTP so any origin is fine in dev.
CORS_ORIGINS=*

# Local media storage (dev). Uploaded images + derivatives are written here and
# served back by the API. In production this is replaced by Cloudflare R2.
MEDIA_DIR=.media
# Base URL the API is reachable at — used to build media URLs handed to the app.
PUBLIC_BASE_URL=http://localhost:3000/api/v1
